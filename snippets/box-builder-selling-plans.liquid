{%- assign recharge_app_id = '294517' -%}

<div id='card__variants'>
  {%- assign recharge_selling_plan_groups = card_product.selling_plan_groups | where: 'app_id', recharge_app_id -%}
  {%- assign recharge_plan_ids = ',' -%}
  {%- for selling_plan_group in recharge_selling_plan_groups -%}
    {%- for selling_plan in selling_plan_group.selling_plans -%}
      {%- assign recharge_plan_ids = recharge_plan_ids | append: selling_plan.id | append: ',' -%}
    {%- endfor -%}
  {%- endfor -%}

  {%- for variant in card_product.variants -%}
    {%- assign recharge_allocation = null -%}
    {%- for allocation in variant.selling_plan_allocations -%}
      {%- assign allocation_plan_match = ',' | append: allocation.selling_plan.id | append: ',' -%}
      {%- if recharge_plan_ids contains allocation_plan_match -%}
        {%- assign recharge_allocation = allocation -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    <div class='card__variants-item{% if variant.metafields.custom.hide_from_box_builder == true %} card__variants-item--hide{% endif %}'>
      <div class='card__variants-price'>
        {%- if variant.compare_at_price and recharge_allocation -%}
          <div class='price compare-price'>
            {{- recharge_allocation.compare_at_price | money -}}
          </div>
        {%- endif -%}

        {% assign discount_decimal = section.settings.subscription_discount | divided_by: 100.00 %}
        {% assign discount_rate = 1 | minus: discount_decimal %}
        {% assign discounted_price = recharge_allocation.compare_at_price | times: discount_rate %}

        <div class='subscription-price__label'>Subscription price</div>
        <div class='price'>
          {% if recharge_allocation %}
            <s class='price-item price-item--regular variant-item__old-price'>
              {{ recharge_allocation.price | money }}
            </s>
            <span class='price-item price-item--regular'> {{ discounted_price | money }} </span>
          {% else %}
            <span class='price-item price-item--regular'>
              {{ variant.price | money }}
            </span>
          {% endif %}
        </div>
      </div>

      {%- if variant.available == true -%}
        <div class='card__variants-variant' id='{{ variant.id }}' data-variant>
          <ul class='card__variant-selling-plans hidden'>
            {%- for allocation in variant.selling_plan_allocations -%}
              {%- assign allocation_plan_match = ',' | append: allocation.selling_plan.id | append: ',' -%}
              {%- if recharge_plan_ids contains allocation_plan_match -%}
                {%- for option in allocation.selling_plan.options -%}
                  {%- if option.value contains '-week' -%}
                    {%- assign frequency = option.value | remove: '-week' | strip -%}

                    <li
                      value='{{ frequency }}'
                      data-selling-plan-id='{{ allocation.selling_plan.id }}'
                      data-selling-plan-price='{{ allocation.price }}'
                    >
                      {{- allocation.selling_plan.name -}}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>

          <div class='card__variants-title hidden'>
            {%- if variant.title == 'Default Title' -%}
              Single Item
            {%- elsif variant.title == 'Small' -%}
              {{- variant.title -}}
            {%- elsif variant.title == 'Medium' -%}
              {{- variant.title -}}
            {%- else -%}
              {{- variant.title -}}
            {%- endif -%}
          </div>

          <div class='card__variants-quantity'>
            <div class='cart-item__quantity'>
              <product-button
                id='Button-{{ variant.id }}'
                {% if upsell %}
                  data-upsell='true'
                {% endif %}
              >
                <button
                  class='quick-add__submit button button--full-width button--primary{% if horizontal_quick_add %} card--horizontal__quick-add{% endif %} card__variants-button{% if upsell %} upsell-add-button{% endif %}'
                  name='add'
                >
                  {{- 'products.product.add' | t -}}
                </button>
              </product-button>

              <div class='cart-item__quantity-wrapper hidden'>
                <label class='visually-hidden' for='Quantity-{{ variant.id }}'>
                  {{- 'products.product.quantity.label' | t -}}
                </label>

                <box-quantity-input
                  class='quantity'
                  {% if upsell %}
                    data-upsell='true'
                  {% endif %}
                >
                  <button class='quantity__button no-js-hidden' name='minus' type='button'>
                    <span class='visually-hidden'>
                      {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                    </span>

                    {%- render 'icon-minus' -%}
                  </button>

                  <input
                    class='quantity__input'
                    data-product-quantity
                    type='number'
                    name='updates[]'
                    value='0'
                    min='0'
                    aria-label='{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}'
                    id='Quantity-{{ variant.id }}'
                    data-index='{{ variant.id }}'
                    data-product-id='{{ card_product.id }}'
                    data-price='{{ variant.price }}'
                    data-title='{{ card_product.title }}'
                    data-variant-title='{{ variant.title }}'
                    {% if card_product.featured_media %}
                      data-image-url='{{ card_product.featured_media | image_url: width: 150 }}'
                    {% endif %}
                  >

                  <button class='quantity__button no-js-hidden' name='plus' type='button'>
                    <span class='visually-hidden'>
                      {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                    </span>

                    {%- render 'icon-plus' -%}
                  </button>
                </box-quantity-input>
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <span class='card__variants-soldout'> SOLD OUT </span>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>
